{
  "MCP": {
    "Transport": "stdio"
  },
  "Urls": "http://127.0.0.1:0",
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "hostBuilder": {
    "reloadConfigOnChange": false
  },
  "Mcp": {
    "OAuth": {
      "Schemes": {
        "InMemory": { "Enabled": false },
        "EntraId": { "Enabled": false },
        "Auth0": { "Enabled": false }
      }
    }
  },
  "RateLimiterOptions": {
    "Enabled": false
  }
}
