{
  "MCP": {
    "Transport": "http"
  },
  "Mcp": {
  },
  "Logging": {
    "LogLevel": {
      "Default": "Trace",
      "Microsoft.AspNetCore": "Trace"
    },
    "Console": {
      "LogLevel": {
        "Default": "Trace",
        "Microsoft.AspNetCore": "Trace"
      }
    }
  },
  "RateLimiterOptions": {
    "Enabled": true,
    "FixedWindowRateLimit": {
      "AutoReplenishment": true,
      "PermitLimit": 10,
      "Window": "00:01:00"
    },
    "McpWindowRateLimit": {
      "AutoReplenishment": true,
      "PermitLimit": 30,
      "Window": "00:01:00"
    }
  }  
}
