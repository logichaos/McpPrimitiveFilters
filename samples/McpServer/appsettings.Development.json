{
  "MCP": {
    "Transport": "http"
  },
  "Mcp": {
    "OAuth": {
      "DefaultScheme": "InMemory",
      "ServerUrl": "https://localhost:7072/",
      "Schemes": {
        "InMemory": {
          "Enabled": true,
          "Audience": "http://localhost:7071/",
          "DisableBackchannelSslValidation": true
        },
        "EntraId": {
          "Enabled": false
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Debug"
    },
    "Console": {
      "LogLevel": {
        "Default": "Debug",
        "Microsoft.AspNetCore": "Debug"
      }
    }
  },
  "RateLimiterOptions": {
    "Enabled": true,
    "FixedWindowRateLimit": {
      "AutoReplenishment": true,
      "PermitLimit": 10,
      "Window": "00:01:00"
    },
    "McpWindowRateLimit": {
      "AutoReplenishment": true,
      "PermitLimit": 30,
      "Window": "00:01:00"
    }
  },
  "McpFiltering": {
    "Allowed": {
      "tools": ["get_random_number", "get_timestamp", "echo", "list_users", "get_server_stats"],
      "resources": ["Server Info", "Process Info", "City Weather", "Current Time"]
    }
  }
}
