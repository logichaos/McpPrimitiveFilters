{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OTEL_EXPORTER_OTLP_ENDPOINT": "",
  "AllowedHosts": "localhost;127.0.0.1;[::1]",
  "MCP": {
    "Transport": "http"
  },
  "Mcp": {
    "OAuth": {
      "DefaultScheme": "EntraId",
      "ServerUrl": "",
      "ScopesSupported": ["mcp:tools"],
      "ResourceDocumentation": "https://docs.example.com/api",
      "Schemes": {
        "InMemory": {
          "Enabled": false,
          "DisplayName": "Local Dev OAuth Server",
          "Type": "InMemory",
          "AuthorityUrl": "https://localhost:7029",
          "DisableBackchannelSslValidation": false
        },
        "EntraId": {
          "Enabled": false,
          "DisplayName": "Microsoft Entra ID",
          "Type": "EntraId",
          "TenantId": "",
          "Instance": "https://login.microsoftonline.com/",
          "ClientId": "",
          "DisableBackchannelSslValidation": false
        },
        "Auth0": {
          "Enabled": false,
          "DisplayName": "Auth0",
          "Type": "Auth0",
          "Domain": "",
          "ClientId": "",
          "DisableBackchannelSslValidation": false
        }
      }
    }
  },
  "RateLimiterOptions": {
    "Enabled": true,
    "FixedWindowRateLimit": {
      "AutoReplenishment": true,
      "PermitLimit": 40,
      "Window": "00:02:00"
    },
    "McpWindowRateLimit": {
      "AutoReplenishment": true,
      "PermitLimit": 100,
      "Window": "00:01:00"
    }
  },
  "McpFiltering": {
    "Allowed": {
      "tools": null,
      "resources": null
    }
  }
