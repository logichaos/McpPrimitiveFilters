{
  "RunConfiguration": {
    "CollectSourceLink": false
  },
  "DataCollection": {
    "CodeCoverage": {
      "Enable": true,
      "ExcludeByAssembly": [
        "*.TestOAuthServer",
        "*.Integration.Tests",
        "*.Unit.Tests",
        "McpServer",
        "McpServer.Core",
        "TestApp",
        "TUnit.*",
        "Serilog.*"
      ],
      "ExcludeByFile": [
        "**/samples/**",
        "**/Program.cs",
        "**/appsettings*.json",
        "**/launchSettings.json"
      ]
    }
  }
}
